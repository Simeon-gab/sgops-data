# SgOps Data — Environment Variables
# Copy this file to .env.local and fill in your values
# All variables marked NEXT_PUBLIC_* are exposed to the browser

# ━━━ Supabase ━━━
# Get from: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — server only, never expose to browser
# Required for webhooks and background jobs that run without a user session
SUPABASE_SERVICE_ROLE_KEY=

# ━━━ Anthropic (Claude API) ━━━
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ━━━ Google Places API ━━━
# Get from: https://console.cloud.google.com/apis/credentials
# Enable: Places API (New)
# Without this key the app runs in demo mode with mock data
GOOGLE_PLACES_API_KEY=

# ━━━ SerpAPI (fallback extraction) ━━━
# Get from: https://serpapi.com/
SERPAPI_KEY=

# ━━━ Hunter.io (email verification) ━━━
# Get from: https://hunter.io/api-keys
HUNTER_API_KEY=

# ━━━ Resend (email sending) ━━━
# Get from: https://resend.com/api-keys
RESEND_API_KEY=
# The "from" address used for outreach emails
# Must be a verified domain in your Resend account
# Falls back to onboarding@resend.dev if not set (Resend sandbox, limited recipients)
RESEND_FROM_EMAIL=

# ━━━ Resend Webhooks (optional, for delivery tracking) ━━━
# Configure at: https://resend.com/webhooks
# Webhook URL: https://<your-domain>/api/webhooks
# Required events: email.sent, email.delivered, email.opened, email.clicked,
#                  email.bounced, email.delivery_delayed, email.complained
# Secret is used for Svix signature verification (production hardening)
RESEND_WEBHOOK_SECRET=
